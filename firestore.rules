rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'akunmlzarr22@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // 2. Products: Public read, Admin write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 3. Users: User can read/write their own, Admin can do all
    match /users/{username} {
      allow read: if true; // Public for login lookup, though can be hardened
      allow write: if true; // Public for registration, though can be hardened
    }

    // 4. Orders: Owner and Admin
    match /orders/{orderId} {
      allow read: if true; 
      allow write: if true; 
    }

    // 5. Topups: Owner and Admin
    match /topups/{topupId} {
      allow read: if true; 
      allow write: if true; 
    }

    // 6. Messages: Sender, Recipient, and Admin
    match /messages/{messageId} {
      allow read: if true;
      allow write: if true;
    }

    // 7. Settings: Public read, Admin write
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
